{
  "nodeModulesDir": "auto",
  "tasks": {
    "dev": "npm run dev",
    "build": "npm run build",
    "preview": "npm run preview"
  },
  "imports": {
    "@std/expect": "jsr:@std/expect@^1.0.18",
    "@std/testing": "jsr:@std/testing@^1.0.17"
  },
  "lint": {
    "exclude": [
      "build/",
      "coverage/",
      "node_modules/",
      "out/",
      "dist/"
    ]
  },
  "fmt": {
    "exclude": [
      "build/",
      "coverage/",
      "node_modules/",
      "out/",
      "dist/"
    ]
  }
}
