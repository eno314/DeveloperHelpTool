{
  "nodeModulesDir": "auto",
  "tasks": {
    "dev": "deno run -A --node-modules-dir npm:next dev",
    "dev:client": "deno run -A --node-modules-dir npm:vite",
    "build:client": "deno run -A --node-modules-dir npm:vite build",
    "build": "deno task build:client && deno run -A --node-modules-dir npm:next build",
    "start": "deno run -A --node-modules-dir npm:next start"
  },
  "imports": {
    "@std/expect": "jsr:@std/expect@^1.0.18",
    "@std/testing": "jsr:@std/testing@^1.0.17"
  },
  "lint": {
    "exclude": [
      ".next/",
      "build/",
      "coverage/",
      "node_modules/",
      "out/",
      "dist/"
    ]
  },
  "fmt": {
    "exclude": [
      ".next/",
      "build/",
      "coverage/",
      "node_modules/",
      "out/",
      "dist/",
      "src/components/molecules/JSONCompareForm/JSONCompareForm.tsx"
    ]
  }
}
