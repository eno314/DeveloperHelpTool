{
  "nodeModulesDir": "auto",
  "tasks": {
    "dev": "deno run -A --node-modules-dir npm:vite",
    "build": "deno run -A --node-modules-dir npm:vite build",
    "start:hono": "deno serve -A src/server.ts"
  },
  "imports": {
    "@std/expect": "jsr:@std/expect@^1.0.18",
    "@std/testing": "jsr:@std/testing@^1.0.17"
  },
  "lint": {
    "exclude": [
      "build/",
      "coverage/",
      "node_modules/",
      "out/",
      "dist/"
    ]
  },
  "fmt": {
    "exclude": [
      "build/",
      "coverage/",
      "node_modules/",
      "out/",
      "dist/"
    ]
  }
}
