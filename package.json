{
  "name": "nextjs",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "dev:client": "vite",
    "build": "npm run build:client && next build",
    "build:client": "vite build",
    "start": "next start",
    "test": "deno test -A",
    "test:watch": "deno test -A --watch",
    "test:coverage": "deno test -A --coverage",
    "lint": "deno lint",
    "lint:fix": "deno fmt && deno lint",
    "compile": "tsc",
    "prepare": "npm run compile",
    "pretest": "npm run compile",
    "posttest": "npm run lint"
  },
  "dependencies": {
    "bootstrap": "5.x",
    "hono": "^4.12.8",
    "next": "^16.1.6",
    "react": "19",
    "react-dom": "19"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/deno": "^2.5.0",
    "@types/node": "^24.12.0",
    "@types/react": "19",
    "@types/react-dom": "19",
    "typescript": "^5.9.3",
    "vite": "^8.0.1"
  },
  "overrides": {
    "tmp": "^0.2.5"
  }
}
